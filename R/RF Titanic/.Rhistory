titanic %>% select_if(is.numeric())
titanic %>% select_if(is.numeric)
titanic_num <- titanic %>% select_if(is.numeric)
mat_cor <- dplyr::select(titanic_num,-Survived) %>% cor(method="pearson") %>% round(digits=2)
mat_cor
library(corrplot)
